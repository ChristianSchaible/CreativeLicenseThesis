---
interface Props {
  rule: string;
  description: string;
  process: string;
  images?: string[];
  href?: string;
  transitionName?: string;
}

const { rule, description, process, images = [], href, transitionName } = Astro.props;

const ruleUrl = href || '#';
---

<a href={ruleUrl} class="rule-card-link">
  <article class="rule-card" transition:name={transitionName}>
    <header class="rule-card__header">
      <h2 class="rule-card__title">"{rule}"</h2>
    </header>
  </article>
</a>

<style>
  .rule-card-link {
    text-decoration: none;
    color: inherit;
    display: block;
    transition: opacity 0.3s ease;
  }

  .rule-card-link:hover {
    opacity: 0.8;
  }

  .rule-card {
    background-color:;
    padding-block: 1rem;
    border: 1px solid var(--color-accent);
    border-radius: 5px;
    cursor: pointer;
    margin-bottom: var(--margin);
    margin-left: var(--margin);
  }

  .rule-card__header {
    margin: var(--margin)
    }

  .rule-card__title {
    font-family: var(--font-headings);
    font-size: clamp(2rem, 6vw, 5rem);
    line-height: 1.05;
    text-transform: uppercase;
    letter-spacing: -0.02em;
  }
</style>
