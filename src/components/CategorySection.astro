---
// Category Section component
import RuleCard from "./RuleCard.astro";

export interface Props {
  title: string;
  sectionId: string;
  rules: Array<{
    title: string;
    description: string;
    process: string;
    images: string[];
  }>;
}

const { title, sectionId, rules } = Astro.props;
---

<section class="category-section" data-section={sectionId} id={sectionId}>
  <div class="category-container">
    <header class="category-header">
      <h1 class="category-title">{title}</h1>
    </header>

    <div class="rules-grid">
      {rules.map((rule, index) => (
        <RuleCard
          title={rule.title}
          description={rule.description}
          process={rule.process}
          images={rule.images}
          client:load
        />
      ))}
    </div>
  </div>
</section>

<style>
  .category-section {
    min-height: 100vh;
    padding: 4rem 2rem;
    scroll-margin-top: 2rem;
  }

  .category-container {
    max-width: 1200px;
    margin: 0 auto;
  }

  .category-header {
    margin-bottom: 4rem;
    text-align: center;
  }

  .category-title {
    font-family: var(--font-headings);
    font-size: clamp(2rem, 5vw, 3.5rem);
    color: var(--color-accent);
    font-variation-settings: "wdth" 150, "wght" 700, "slnt" 0;
    line-height: 1.1;
    margin: 0;
  }

  .rules-grid {
    display: grid;
    gap: 4rem;
  }

  /* Mobile adjustments */
  @media (max-width: 768px) {
    .category-section {
      padding: 2rem 1rem;
    }

    .category-header {
      margin-bottom: 2rem;
    }

    .rules-grid {
      gap: 2rem;
    }
  }
</style>