---
import Layout from "@layouts/Layout.astro";
import Container from "@components/Container.astro";
import content from "@content/craft.json";

interface Params {
  id: string;
}

// Generate static paths for all rules
export function getStaticPaths() {
  return content.rules.map((rule) => ({
    params: {
      id: rule.rule
        .toLowerCase()
        .replace(/[^\w\s-]/g, "")
        .replace(/\s+/g, "-"),
    },
    props: {
      rule: rule.rule,
      description: rule.description,
      process: rule.process,
      images: rule.images || [],
    },
  }));
}

interface Props {
  rule: string;
  description: string;
  process: string;
  images: string[];
}

const { rule, description, process, images } = Astro.props;
const slug = rule
  .toLowerCase()
  .replace(/[^\w\s-]/g, "")
  .replace(/\s+/g, "-");
const transitionName = `rule-title-craft-${slug}`;
---

<Layout title={rule}>
  <Container>
    <article class="rule-detail">
      <header class="rule-detail__header" transition:name={transitionName}>
        <h1 class="rule-detail__title">"{rule}"</h1>
      </header>
      <div class="output">
        <h1 class="section-layout__subtitle">Output</h1>
        <div class="rule-detail__content">
        <section class="rule-detail__section">
          <h2 class="rule-detail__subtitle">Description</h2>
          <p class="rule-detail__text">{description}</p>
        </section>

        <section class="rule-detail__section">
          <h2 class="rule-detail__subtitle">Process</h2>
          <p class="rule-detail__text">{process}</p>
        </section>

        {images.length > 0 && (
          <section class="rule-detail__section rule-detail__images">
            <h2 class="rule-detail__subtitle">Images</h2>
            <div class="rule-detail__gallery">
              {images.map((image) => (
                <figure class="rule-detail__figure">
                  <img src={image} alt={rule} class="rule-detail__img" />
                </figure>
              ))}
            </div>
          </section>
        )}
      </div>
      </div>
      

      <footer class="rule-detail__footer">
        <a href="/craft" class="rule-detail__back-link">← Back to Rules of Craft</a>
      </footer>
    </article>
  </Container>
</Layout>

<style>

  .rule-detail {
  }

  .rule-detail__header {
    margin: var(--margin);
    
    }

  .rule-detail__title {
    font-family: var(--font-headings);
    font-size: clamp(2.5rem, 8vw, 7rem);
    line-height: 1.2;
    text-transform: uppercase;
    letter-spacing: -0.02em;
    margin: var(--margin);
  }

  .rule-detail__content {
    max-width: 65ch;
    margin: var(--margin);
    display: flex;
    flex-direction: column;
  }

  .rule-detail__section {
    opacity: 0;
    transform: translateY(18px);
    animation: detail-fade-up 560ms ease-out forwards;
  }

  .rule-detail__section:nth-of-type(1) {
    animation-delay: 80ms;
  }

  .rule-detail__section:nth-of-type(2) {
    animation-delay: 180ms;
  }

  .rule-detail__section:nth-of-type(3) {
    animation-delay: 280ms;
  }

  .rule-detail__subtitle {
    font-family: var(--font-headings);
    font-size: clamp(1.5rem, 4vw, 2.5rem);
    text-transform: uppercase;
    letter-spacing: -0.01em;
    margin-bottom: 1.5rem;
    border-bottom: 1px solid var(--color-accent);
    padding-bottom: 0.75rem;
  }

  .rule-detail__text {
    font-size: clamp(1rem, 2vw, 1.125rem);
    line-height: 1.6;
    margin-bottom: 1rem;
  }

  .rule-detail__images {
    max-width: 100%;
  }

  .rule-detail__gallery {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 2rem;
  }

  .rule-detail__figure {
    margin: 0;
  }

  .rule-detail__img {
    width: 100%;
    height: auto;
    display: block;
  }

  .rule-detail__footer {
    margin-top: 4rem;
    padding-top: 2rem;
    border-top: 1px solid var(--color-accent);
    opacity: 0;
    transform: translateY(18px);
    animation: detail-fade-up 560ms ease-out 360ms forwards;
  }

  .rule-detail__back-link {
    font-family: var(--font-headings);
    font-size: 1rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    text-decoration: none;
    color: var(--color-accent);
    transition: opacity 0.3s ease;
  }

  .rule-detail__back-link:hover {
    opacity: 0.7;
  }
  .output {
    display: flex;
    flex-direction: row;
    align-items: flex-start;
  }

  .section-layout__subtitle {
    font-family: var(--font-headings);
    font-size: 10rem;
    writing-mode: vertical-rl;   /* makes text vertical */
    transform: rotate(180deg);   /* flips it to read top-down */
    text-orientation: mixed;
    text-align: right;
    line-height: 1.2;
    letter-spacing: -0.02em;
    background-color: blue;
    padding: 16px 8px;
    border: 1px solid #fff;
    border-radius: 5px;
    color: white;
    opacity: 0;
    animation: section-fade-up-rotated 560ms ease-out 180ms forwards;
    height: fit-content;
    margin: 0;
 font-variation-settings: "wght" 900, "wdth" 150, "slnt" 0;
      position: sticky;
     top: 2rem;
  }

  @keyframes detail-fade-up {
    from {
      opacity: 0;
      transform: translateY(18px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes section-fade-up-rotated {
    from {
      opacity: 0;
      transform: rotate(180deg) translateY(18px);
    }
    to {
      opacity: 1;
      transform: rotate(180deg) translateY(0);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .rule-detail__section,
    .rule-detail__footer,
    .section-layout__subtitle {
      animation: none;
      opacity: 1;
    }

    .rule-detail__section,
    .rule-detail__footer {
      transform: none;
    }

    .section-layout__subtitle {
      transform: rotate(180deg);
    }
  }
</style>
